# Optional: Gemini API key for cloud-acceleration (get free at https://aistudio.google.com/apikey)
# If left empty, CarnetLM will default to local Ollama.
GEMINI_API_KEY=

# Local Ollama configuration (Required for local-first offline use)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5

# Optional: Local Orpheus TTS (https://github.com/legraphista/LocalOrpheusTTS)
# ORPHEUS_TTS_URL=http://localhost:5005
# ORPHEUS_VOICE=tara